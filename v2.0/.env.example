APP_NAME=Hybrid Store Stand
APP_VERSION=2.0.0

API_IMAGE_NAME=hybrid-store-api
API_IMAGE_TAG=2.0.0
API_BUILD_VERSION=2.0.0

NGINX_IMAGE=nginx:1.27-alpine
NGINX_CONTAINER_NAME=hybrid_store_nginx
NGINX_BIND_ADDRESS=127.0.0.1
NGINX_PORT=8082

MONGO_IMAGE=mongo:7.0
MONGO_CONTAINER_NAME=hybrid_store_mongodb
MONGO_BIND_ADDRESS=127.0.0.1
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123
MONGO_DB_NAME=hybrid_store
MONGO_APP_USER=store_user
MONGO_APP_PASSWORD=store123
MONGO_URI=mongodb://store_user:store123@mongodb:27017/hybrid_store?authSource=hybrid_store
MONGO_PRODUCTS_COLLECTION=products

POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=hybrid_store_postgres
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=hybrid_store
POSTGRES_USER=store_admin
POSTGRES_PASSWORD=admin123
POSTGRES_DSN=postgresql://store_admin:admin123@postgres:5432/hybrid_store
